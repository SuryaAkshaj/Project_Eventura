# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# DATABASE_URL: Connection string through PgBouncer (port 6432).
#   Format: postgresql://<user>:<password>@<host>:6432/<database>
#   In production: use Railway's PgBouncer proxy URL or Supabase pooler URL
#
# DIRECT_URL: Direct PostgreSQL connection (port 5432) — used by Prisma Migrate ONLY.
#   In production: use Railway private networking URL or Supabase direct URL
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>:6432/<database>"
DIRECT_URL="postgresql://<user>:<password>@<host>:5432/<database>"

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# REDIS_URL: Full Redis connection URL
#   In production: use Railway Redis or Upstash URL
# REDIS_PASSWORD: Password set with --requirepass
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://<host>:6379"
REDIS_PASSWORD="<your-redis-password>"

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Generate using: node -e "require('crypto').randomBytes(64).toString('hex')"
# JWT_ACCESS_EXPIRY: Short-lived access token (e.g. 15m)
# JWT_REFRESH_EXPIRY: Long-lived refresh token (e.g. 7d)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET="<min-64-char-random-hex-string>"
JWT_REFRESH_SECRET="<min-64-char-random-hex-string-different-from-above>"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY — https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for development, live keys for production
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_<your-key-id>"
RAZORPAY_KEY_SECRET="<your-key-secret>"
RAZORPAY_WEBHOOK_SECRET="<webhook-secret-from-razorpay-dashboard>"

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY — https://cloudinary.com/console
# Used for uploading event banners, org logos, and certificates
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="<your-cloud-name>"
CLOUDINARY_API_KEY="<your-api-key>"
CLOUDINARY_API_SECRET="<your-api-secret>"

# ─────────────────────────────────────────────────────────────────────────────
# RESEND — https://resend.com/api-keys
# Used for transactional emails (OTP, certificate delivery, invites)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_<your-api-key>"

# ─────────────────────────────────────────────────────────────────────────────
# APP
# CLIENT_URL: Frontend URL for CORS whitelist (e.g. https://eventura.app in production)
# PORT: Backend server port (default 4000)
# NODE_ENV: "development" | "production" | "test"
# ─────────────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
PORT=4000
NODE_ENV="development"

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="<your-google-client-id>"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"
